#!/usr/bin/env bash
set -euo pipefail

# =============================================================================
# install-aetheria — single-command Aetheria cluster installer
#
# Locates or builds the node installer bundle, then runs the full cluster
# deployment. All flags are passed through to deploy-cluster.sh.
#
# Usage:
#   sudo bash install-aetheria [--use-portal] [--identity FILE] [--resume]
#                              [--force] [--skip-preflight]
#
# Optional environment variables:
#   AETHERIA_SRC           Path to Aetheria source repo (for building installer)
#   AETHERIA_INSTALLER_DIR Path to directory containing installer tarball
# =============================================================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WORK_DIR="${SCRIPT_DIR}/downloads"
CACHE_DIR="/var/cache/aetheria"
PUBLIC_REPO="desolator17/AetheriaAIFirewall"
RELEASE_API="https://api.github.com/repos/${PUBLIC_REPO}/releases/latest"

# $'...' syntax ensures escape sequences are actual bytes, not literal strings
RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'
CYAN=$'\033[0;36m'; NC=$'\033[0m'

info() { printf "${GREEN}[INFO]${NC}  %s\n" "$*"; }
warn() { printf "${YELLOW}[WARN]${NC}  %s\n" "$*"; }
err()  { printf "${RED}[ERR ]${NC}  %s\n" "$*" >&2; exit 1; }
step() { printf "\n${CYAN}>>> %s${NC}\n" "$*"; }

# ---------------------------------------------------------------------------
# Find installer tarball in known locations (most specific first, no broad scan)
# ---------------------------------------------------------------------------
find_installer() {
  local dirs=(
    "${AETHERIA_INSTALLER_DIR:-}"
    "$WORK_DIR"
    "$CACHE_DIR"
    "$HOME/downloads"
    "/root/downloads"
    "/tmp"
    "/var/tmp"
    "/opt"
  )
  local d f
  for d in "${dirs[@]}"; do
    [[ -z "$d" || ! -d "$d" ]] && continue
    for f in \
      "${d}"/aetheria-*-installer.tar.gz \
      "${d}"/aetheria-*-installer.tgz \
      "${d}"/aetheria-*-installer.tar; do
      [[ -f "$f" ]] && echo "$f" && return 0
    done
  done
  return 1
}

# ---------------------------------------------------------------------------
# Locate build-installer.sh.
# Uses find(1) rather than glob expansion to avoid permission-denied silences.
# Searches: AETHERIA_SRC → sibling dirs → /home, /root, /opt (maxdepth 5)
# ---------------------------------------------------------------------------
find_build_script() {
  # 1. Explicit env var override
  if [[ -n "${AETHERIA_SRC:-}" ]] && [[ -f "${AETHERIA_SRC}/scripts/build-installer.sh" ]]; then
    echo "${AETHERIA_SRC}/scripts/build-installer.sh"
    return 0
  fi

  # 2. Sibling directories alongside this repo
  #    e.g. ~/aetheria-public/ and ~/aetheria/ sit side-by-side under ~/
  local parent result
  parent="$(dirname "$SCRIPT_DIR")"
  result=$(find "$parent" -maxdepth 3 -name "build-installer.sh" \
           -path "*/scripts/build-installer.sh" 2>/dev/null | head -1)
  [[ -n "$result" ]] && echo "$result" && return 0

  # 3. Any home directory subtree — try as root first, then re-run as each
  #    directory owner in case the home dir is mode 750 (root can't traverse)
  result=$(find /home -maxdepth 5 -name "build-installer.sh" \
           -path "*/scripts/build-installer.sh" 2>/dev/null | head -1)
  [[ -n "$result" ]] && echo "$result" && return 0

  if [[ "$(id -u)" -eq 0 ]] && command -v runuser >/dev/null 2>&1; then
    local u
    for u in /home/*/; do
      [[ -d "$u" ]] || continue
      u="$(basename "$u")"
      result=$(runuser -u "$u" -- find "/home/${u}" -maxdepth 4 \
               -name "build-installer.sh" -path "*/scripts/build-installer.sh" \
               2>/dev/null | head -1) || true
      [[ -n "$result" ]] && echo "$result" && return 0
    done
  fi

  # 4. Root home subtree
  result=$(find /root -maxdepth 4 -name "build-installer.sh" \
           -path "*/scripts/build-installer.sh" 2>/dev/null | head -1)
  [[ -n "$result" ]] && echo "$result" && return 0

  # 5. Common system install locations
  result=$(find /opt /usr/local -maxdepth 4 -name "build-installer.sh" \
           -path "*/scripts/build-installer.sh" 2>/dev/null | head -1)
  [[ -n "$result" ]] && echo "$result" && return 0

  return 1
}

# ---------------------------------------------------------------------------
# Download installer from GitHub release.
# Tries /releases/latest first (stable only), then /releases (includes
# pre-releases), so dev builds published with --prerelease are also found.
# ---------------------------------------------------------------------------
_download_from_release() {
  command -v curl >/dev/null 2>&1 || return 1
  local asset_url base_name release_json

  _parse_asset_url() {
    printf '%s' "$1" | \
      grep -Eo 'https://[^"[:space:]]+aetheria-[^"[:space:]]+-installer\.(tar\.gz|tgz|tar)' | \
      head -1
  }

  # 1. Latest stable release
  release_json="$(curl -fsSL "${RELEASE_API}" 2>/dev/null)" || true
  asset_url="$(_parse_asset_url "$release_json")"

  # 2. Fall back to all releases list (catches pre-releases)
  if [[ -z "$asset_url" ]]; then
    release_json="$(curl -fsSL "https://api.github.com/repos/${PUBLIC_REPO}/releases" 2>/dev/null)" || true
    asset_url="$(_parse_asset_url "$release_json")"
  fi

  [[ -n "$asset_url" ]] || return 1

  base_name="$(basename "$asset_url")"
  info "Downloading ${base_name} from GitHub release..."
  curl -fL "$asset_url" -o "${WORK_DIR}/${base_name}" || return 1
  curl -fL "${asset_url}.sha256" -o "${WORK_DIR}/${base_name}.sha256" 2>/dev/null || true
  info "Download complete: ${WORK_DIR}/${base_name}"
}

# ---------------------------------------------------------------------------
# Banner
# ---------------------------------------------------------------------------
printf "${CYAN}"
cat <<'BANNER'

  █████╗ ███████╗████████╗██╗  ██╗███████╗██████╗ ██╗ █████╗
 ██╔══██╗██╔════╝╚══██╔══╝██║  ██║██╔════╝██╔══██╗██║██╔══██╗
 ███████║█████╗     ██║   ███████║█████╗  ██████╔╝██║███████║
 ██╔══██║██╔══╝     ██║   ██╔══██║██╔══╝  ██╔══██╗██║██╔══██║
 ██║  ██║███████╗   ██║   ██║  ██║███████╗██║  ██║██║██║  ██║
 ╚═╝  ╚═╝╚══════╝   ╚═╝   ╚═╝  ╚═╝╚══════╝╚═╝  ╚═╝╚═╝╚═╝  ╚═╝

BANNER
printf "${NC}"
echo "  Aetheria AI Firewall Suite — Cluster Installer"
echo "  ================================================"
echo ""

# ---------------------------------------------------------------------------
# Step 1: Locate installer tarball
# ---------------------------------------------------------------------------
step "Step 1/2 — Locating installer bundle"

INSTALLER_TGZ=""
if INSTALLER_TGZ="$(find_installer)"; then
  info "Found installer: ${INSTALLER_TGZ}"
else
  info "No installer tarball found — searching for build script..."

  BUILD_SCRIPT=""
  if BUILD_SCRIPT="$(find_build_script)"; then
    info "Found build script: ${BUILD_SCRIPT}"
    info "Building installer bundle..."
    mkdir -p "${WORK_DIR}"
    bash "${BUILD_SCRIPT}" --output-dir "${WORK_DIR}"
    INSTALLER_TGZ="$(find_installer)" || true
  else
    info "Build script not found."
  fi

  if [[ -z "${INSTALLER_TGZ:-}" ]]; then
    info "Attempting to download installer from GitHub release..."
    mkdir -p "${WORK_DIR}"
    if _download_from_release; then
      INSTALLER_TGZ="$(find_installer)" || true
    fi
  fi

  if [[ -z "${INSTALLER_TGZ:-}" ]]; then
    echo ""
    warn "Could not locate, build, or download the installer bundle."
    echo ""
    echo "  Provide it one of these ways and re-run:"
    echo ""
    echo "  A) Point to the Aetheria source repo:"
    echo "       AETHERIA_SRC=/path/to/aetheria-src ./install-aetheria"
    echo ""
    echo "  B) Point to an existing tarball directory:"
    echo "       AETHERIA_INSTALLER_DIR=/path/to/dir ./install-aetheria"
    echo ""
    echo "  C) Download from portal:"
    echo "       ./install-aetheria --use-portal"
    echo ""
    echo "  D) Copy tarball manually:"
    echo "       cp aetheria-*-installer.tar.gz ${WORK_DIR}/"
    echo "       ./install-aetheria"
    echo ""
    err "Installer not found. See options above."
  fi
fi

export AETHERIA_INSTALLER_DIR
AETHERIA_INSTALLER_DIR="$(dirname "${INSTALLER_TGZ}")"

# ---------------------------------------------------------------------------
# Step 2: Run deploy-cluster.sh
# ---------------------------------------------------------------------------
step "Step 2/2 — Starting cluster deployment"
info "Installer: ${INSTALLER_TGZ}"
echo ""

exec "${SCRIPT_DIR}/deploy-cluster.sh" "$@"
